menu "TH Sensor Device Configuration"

    choice SENSOR_DEVICE
        prompt "Select Sensor Device"
        default SENSOR_5
        help
            Select which sensor device to build for.
            This can also be set via SENSOR_ID environment variable (1-5).

        config SENSOR_1
            bool "TH_GR - Gowning room 819 A"
            help
                Device ID: 4000
                Device Name: TH_GR
                Location: Gowning room 819 A
        config SENSOR_2
            bool "TH_DR - Deposition room 819C"
            help
                Device ID: 4001
                Device Name: TH_DR
                Location: Deposition room 819C
        config SENSOR_3
            bool "TH_ER - Etch room 819D"
            help
                Device ID: 4002
                Device Name: TH_ER
                Location: Etch room 819D
        config SENSOR_4
            bool "TH_EBLR - EBL room 819E"
            help
                Device ID: 4003
                Device Name: TH_EBLR
                Location: EBL room 819E
        config SENSOR_5
            bool "TH_YR - Yellow room 819F"
            help
                Device ID: 4008
                Device Name: TH_YR
                Location: Yellow room 819F
    endchoice

    config DEVICE_ID
        int
        default 4000 if SENSOR_1
        default 4001 if SENSOR_2
        default 4002 if SENSOR_3
        default 4003 if SENSOR_4
        default 4008 if SENSOR_5

    config DEVICE_DESCRIPTION
        string
        default "Gowning room 819 A" if SENSOR_1
        default "Deposition room 819C" if SENSOR_2
        default "Etch room 819D" if SENSOR_3
        default "EBL room 819E" if SENSOR_4
        default "Yellow room 819F" if SENSOR_5

    config DEVICE_NAME
        string
        default "TH_GR" if SENSOR_1
        default "TH_DR" if SENSOR_2
        default "TH_ER" if SENSOR_3
        default "TH_EBLR" if SENSOR_4
        default "TH_YR" if SENSOR_5

endmenu
